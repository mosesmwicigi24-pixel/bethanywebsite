# Bethany House storefront — environment configuration.
# Copy to .env.local for local dev; set the same keys in the deploy env.
# Nothing here is secret in this file — real values live only in the host env.

# --- Bethany Hub (public reads: catalog, checkout, order tracking) ---
# Inlined at build time (NEXT_PUBLIC_*). Already wired in lib/catalog.ts / lib/hub.ts.
NEXT_PUBLIC_HUB_API=https://hub.bethanyhouse.co.ke/api/v1
# SERVER ONLY. Shared secret sent as X-Storefront-Key on Hub writes (leads,
# interest-carts). Optional — dormant until the Hub gate is enabled (HUB_CONTRACT §6).
HUB_STOREFRONT_KEY=

# --- Neema AI (app/api/neema) — SERVER ONLY, never NEXT_PUBLIC_ ---

# Path A — unify with the shared neema-ai brain (the WhatsApp/Messenger/IG agent).
# When BOTH are set, every web chat turn is proxied to that agent — its own
# memory, tools, live-hub grounding and human takeover ("one Neema everywhere").
# If unset or the agent is unreachable, the storefront's own gateway below answers,
# so the widget never breaks. The X-Storefront-Key is sent server-side only.
NEEMA_AGENT_URL=
NEEMA_AGENT_KEY=
# Chat runs a fallback chain over the configured providers. NEEMA_CHAT_PRIMARY
# picks who answers first; the rest are automatic fallbacks. Only providers whose
# key is set are used; with none set, a deterministic catalog-grounded fallback
# still answers, so the chat works in demo mode.

# Who answers first (change anytime, no redeploy):
#   openai   — GPT-4o, most natural (best balance of quality/cost) [default]
#   anthropic— Claude Opus, top quality, highest cost
#   gemini   — cheap + fast upgrade over groq
#   groq     — cheapest & fastest, weakest conversation
NEEMA_CHAT_PRIMARY=openai

# Groq (OpenAI-compatible). llama-3.3-70b-versatile is text-only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1

# Fallback 1 — Anthropic (native Messages API). Defaults to the most capable
# Opus tier; set a cheaper model (e.g. claude-haiku-4-5) if you prefer.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_API_URL=https://api.anthropic.com/v1

# Fallback 2 — OpenAI (native OpenAI API). gpt-4o does tools + vision. A
# service-account key (sk-svcacct-…) works the same as a standard key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_API_URL=https://api.openai.com/v1

# Fallback 3 — Gemini (OpenAI-compatible). Multimodal, so it also powers vision.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Vision (measurement copilot) runs Gemini -> OpenAI -> Anthropic — Groq/Llama
# is text-only. Each defaults to that provider's main model above; override
# here only for a dedicated vision model.
GEMINI_VISION_MODEL=
OPENAI_VISION_MODEL=
ANTHROPIC_VISION_MODEL=

# --- Neema health check (app/api/neema/health) ---
# Optional. When set, GET /api/neema/health requires ?token=<this value> and
# returns 401 otherwise, so the provider list stays private. Leave blank to
# keep the check open (fine for local dev). Use a long random string.
NEEMA_HEALTH_TOKEN=
