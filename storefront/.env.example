# Bethany House storefront — environment configuration.
# Copy to .env.local for local dev; set the same keys in the deploy env.
# Nothing here is secret in this file — real values live only in the host env.

# --- Bethany Hub (public reads: catalog, checkout, order tracking) ---
# Inlined at build time (NEXT_PUBLIC_*). Already wired in lib/catalog.ts / lib/hub.ts.
NEXT_PUBLIC_HUB_API=https://hub.bethanyhouse.co.ke/api/v1

# --- Neema AI gateway (app/api/neema) — SERVER ONLY, never NEXT_PUBLIC_ ---
# When NEEMA_API_KEY is unset, the gateway runs a deterministic, catalog-grounded
# fallback so the chat still works. Set the key to route through Grok.
# OpenAI-compatible endpoint (xAI by default; or your Neema/Grok proxy in Docker).
NEEMA_API_KEY=
NEEMA_API_URL=https://api.x.ai/v1
NEEMA_MODEL=grok-4
# Vision model for the measurement copilot (app/api/neema/measure). Unset falls
# back to NEEMA_MODEL — grok-4 is multimodal. Set a dedicated vision model here
# only if your chat model isn't (e.g. grok-2-vision-1212).
NEEMA_VISION_MODEL=
